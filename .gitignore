# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local agent / Codex skill cache
.agents/
skills-lock.json

# claude settings — ignore everything under .claude/ (must use /* so Git still
# descends into re-included subdirs below; a bare `.claude/` would block them)
.claude/*
!.claude/skills/

# project-scoped Claude skills (kept local, not shared with the team) ...
.claude/skills/*
# ... except the mermaid skill, which is version-controlled and shared with the team
!.claude/skills/mermaid/

# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

# IDE / local tooling (not shared with the team)
.idea/
.design-sync/

# Obsidian vault workspace state (repo doubles as a vault)
.obsidian/
